# Amazon Bedrock — AML-Hackathon project (us-east-1)
AWS_REGION=us-east-1

# Chat: Nova 2 Lite (works without Anthropic use-case form)
BEDROCK_MODEL_ID=global.amazon.nova-2-lite-v1:0
# RAG embeddings: Cohere Embed (works immediately)
BEDROCK_EMBED_MODEL_ID=cohere.embed-english-v3

# Long-term API key from Bedrock console -> API keys
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key-here

# ---------------------------------------------------------------------------
# Database (default: SQLite — no Docker required)
# Leave DATABASE_URL empty → sqlite:///data/lowtrans.db (auto-created on start).
# USE_DB defaults to true; set false only to force JSON-file fallback.
# ---------------------------------------------------------------------------
USE_DB=true
# DATABASE_URL=
# SQLITE_PATH=   # optional; default is <repo>/data/lowtrans.db

# Optional Postgres + pgvector (docker compose up -d). If set but unreachable,
# the API falls back to SQLite automatically.
# DATABASE_URL=postgresql://lowtrans:lowtrans@localhost:5432/lowtrans

# Option B: IAM credentials (production / ECS task role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Production CORS — comma-separated exact origins (Vercel *.vercel.app is already allowed by regex)
# CORS_ORIGINS=https://your-app.vercel.app

# Optional API key gate (frontend sends via NEXT_PUBLIC_API_KEY)
# API_KEY=
